{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>cerbos/renovate",
        "group:allNonMajor",
        ":combinePatchMinorReleases"
    ],
    "packageRules": [
        {
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "GitHub Actions deps",
            "groupSlug": "gh-actions-deps"
        },
        {
            "matchManagers": [
                "gomod"
            ],
            "groupName": "Go deps",
            "groupSlug": "go-deps"
        },
        {
            "matchPackageNames": [
                "cerbos/actions",
                "github.com/cerbos/actions"
            ],
            "groupName": "cerbos/actions",
            "groupSlug": "cerbos-actions"
        }
    ],
    "labels": [
        "kind/chore",
        "area/ci",
        "bots"
    ]
}
